    "maintainer": "coffeebreak-chicken",
    "url": "https://github.com/coffeebreak-chicken/Keyboard",
    "usb": {
        "vid": "0x355D",               // Vial プロジェクト
        "pid": "0x4752",               // GHのASCII値0x(https://caniusevia.com/docs/configuring_qmk/#change-vendor_id-product_id)
        "device_version": "0.0.1"
    },
    "processor": "RP2040",           // RP2040のMCU
    "bootloader": "rp2040",          // RP2040で一般的なブートローダー
    "diode_direction": "COL2ROW",
    "features": {
        "bootmagic": false,
        "command": false,
        "console": false,
        "extrakey": true,
        "mousekey": true,
        "nkro": false,
        "rgb_matrix": false,        // 複数のLED
        "rgblight": true            // 単体のLED
    },
    "ws2812": {
        "driver": "vendor",
        "pin": "GP2"
    },
